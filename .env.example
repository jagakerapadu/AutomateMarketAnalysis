# Environment Variables Template
# Copy this file to .env and fill in your actual credentials

# Database Configuration
DB_HOST=localhost
DB_PORT=5434
DB_NAME=trading_system
DB_USER=trading_user
DB_PASSWORD=your_secure_password_here

# Zerodha Kite API
# Get these from: https://kite.trade/ → My Apps → Create New App
ZERODHA_API_KEY=your_api_key_from_kite_developers
ZERODHA_API_SECRET=your_api_secret_from_kite_developers
ZERODHA_USER_ID=YOUR_USER_ID
ZERODHA_REQUEST_TOKEN=leave_empty_will_be_generated
ZERODHA_ACCESS_TOKEN=auto_generated_daily_do_not_edit

# ICICI Breeze API (Optional - only if you use ICICI Direct)
ICICI_API_KEY=your_icici_api_key
ICICI_API_SECRET=your_icici_api_secret
ICICI_SESSION_TOKEN=leave_empty

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_DAILY_LOSS=5000
MAX_OPEN_TRADES=5
ENABLE_LIVE_TRADING=false

# Scheduler Times (IST)
PRE_MARKET_TIME=08:45
MARKET_CLOSE_TIME=15:30
POST_MARKET_TIME=16:00

# API Server
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=generate_strong_random_secret_min_32_chars

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and replace all placeholders with your actual credentials
# 3. NEVER commit .env file to Git (already in .gitignore)
# 4. For Zerodha setup, run: python generate_token_quick.py
# 5. For ICICI setup (optional), configure ICICI credentials
#
# SECURITY NOTES:
# - Keep your .env file private and secure
# - Never share API keys/secrets publicly
# - Rotate credentials if exposed
# - Use strong passwords (min 16 chars, mixed case, numbers, symbols)
